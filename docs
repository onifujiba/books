<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Books</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f5f0e8;
      --bg2: #ede7d9;
      --ink: #1c1612;
      --ink2: #4a3f35;
      --accent: #8b3a2a;
      --accent2: #c45e3e;
      --border: #d4c9b5;
      --shadow: rgba(28,22,18,0.12);
      --font-size: 18px;
    }
    .dark {
      --bg: #12100e;
      --bg2: #1c1814;
      --ink: #e8e0d0;
      --ink2: #a89880;
      --accent: #d4724a;
      --accent2: #e8956a;
      --border: #2e2820;
      --shadow: rgba(0,0,0,0.4);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lora', Georgia, serif;
      background: var(--bg);
      color: var(--ink);
      min-height: 100vh;
      transition: background 0.3s, color 0.3s;
    }

    /* ── HEADER ── */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      padding: 0 1.25rem;
      height: 54px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      backdrop-filter: blur(6px);
      box-shadow: 0 2px 12px var(--shadow);
    }

    .header-left { display: flex; align-items: center; gap: 0.5rem; }

    .header-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.02em;
      cursor: pointer;
      user-select: none;
    }

    .header-controls { display: flex; align-items: center; gap: 0.5rem; }

    .icon-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--ink2);
      padding: 6px 8px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      gap: 4px;
      transition: color 0.2s, background 0.2s;
      font-size: 1rem;
      font-family: inherit;
      white-space: nowrap;
    }
    .icon-btn:hover { color: var(--accent); background: var(--border); }
    .icon-btn.active { color: var(--accent); background: var(--border); }

    /* ── TOC DRAWER ── */
    #toc-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 300;
      backdrop-filter: blur(2px);
    }
    #toc-overlay.open { display: block; }

    #toc-drawer {
      position: fixed;
      top: 0; left: 0; bottom: 0;
      width: min(320px, 85vw);
      background: var(--bg2);
      border-right: 1px solid var(--border);
      box-shadow: 4px 0 24px var(--shadow);
      z-index: 301;
      transform: translateX(-100%);
      transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
      display: flex;
      flex-direction: column;
    }
    #toc-drawer.open { transform: translateX(0); }

    .toc-header {
      padding: 1.1rem 1.25rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .toc-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink);
    }
    .toc-close {
      background: none;
      border: none;
      font-size: 1.3rem;
      cursor: pointer;
      color: var(--ink2);
      padding: 2px 6px;
      border-radius: 4px;
    }
    .toc-close:hover { color: var(--accent); background: var(--border); }

    .toc-book-title {
      padding: 0.75rem 1.25rem;
      font-size: 0.8rem;
      color: var(--ink2);
      font-style: italic;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .toc-list {
      overflow-y: auto;
      flex: 1;
      padding: 0.5rem 0;
    }

    .toc-item {
      display: block;
      padding: 0.7rem 1.25rem;
      cursor: pointer;
      color: var(--ink);
      font-size: var(--font-size);
      border-left: 3px solid transparent;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }
    .toc-item:hover { background: var(--bg); border-left-color: var(--accent2); color: var(--accent); }
    .toc-item.current { border-left-color: var(--accent); color: var(--accent); font-weight: 600; background: var(--bg); }

    .toc-ch-label {
      color: var(--ink);
      display: block;
      font-family: 'Playfair Display', serif;
    }
    .toc-ch-title { display: block; font-size: 0.85em; color: var(--ink2); margin-top: 0.1rem; }

    .toc-empty {
      padding: 2rem 1.25rem;
      color: var(--ink2);
      font-style: italic;
      font-size: 0.9rem;
      text-align: center;
    }

    /* ── RESUME BANNER ── */
    #resume-banner {
      display: none;
      background: var(--accent);
      color: #fff;
      padding: 0.6rem 1.25rem;
      font-size: 0.88rem;
      text-align: center;
      gap: 0.75rem;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
    }
    #resume-banner.show { display: flex; }
    #resume-banner button {
      background: rgba(255,255,255,0.2);
      border: 1px solid rgba(255,255,255,0.4);
      color: #fff;
      padding: 2px 10px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.82rem;
    }
    #resume-banner button:hover { background: rgba(255,255,255,0.35); }

    /* ── LIBRARY VIEW ── */
    #library {
      max-width: 640px;
      margin: 0 auto;
      padding: 2.5rem 1.25rem 4rem;
    }

    .library-heading {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 0.4rem;
      line-height: 1.2;
    }
    .library-sub {
      color: var(--ink2);
      font-size: 0.95rem;
      margin-bottom: 2rem;
      font-style: italic;
    }

    .book-list { display: flex; flex-direction: column; gap: 0.75rem; }

    .book-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.1rem 1.25rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    }
    .book-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px var(--shadow);
      border-color: var(--accent2);
    }
    .book-card:active { transform: translateY(0); }

    .book-icon { font-size: 1.6rem; flex-shrink: 0; opacity: 0.8; }
    .book-info { flex: 1; min-width: 0; }

    .book-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .book-meta { font-size: 0.8rem; color: var(--ink2); margin-top: 0.2rem; }
    .book-progress { font-size: 0.75rem; color: var(--accent); margin-top: 0.2rem; font-style: italic; }
    .book-arrow { color: var(--accent); font-size: 1.1rem; flex-shrink: 0; }

    /* ── READER VIEW ── */
    #reader {
      display: none;
      max-width: 680px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 5rem;
    }

    .reader-label {
      font-family: 'Playfair Display', serif;
      font-size: 0.85rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }

    .reader-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 5vw, 2.4rem);
      font-weight: 700;
      line-height: 1.2;
      color: var(--ink);
      margin-bottom: 1.5rem;
      border-bottom: 2px solid var(--border);
      padding-bottom: 1.25rem;
    }

    .reader-body {
      font-size: var(--font-size);
      line-height: 1.85;
      color: var(--ink);
      word-break: break-word;
    }

    .reader-body p { margin-bottom: 1.3em; }

    .chapter-heading {
      font-family: 'Playfair Display', serif;
      font-size: 1.25em;
      font-weight: 700;
      color: var(--ink);
      margin: 2.5em 0 0.9em;
      padding-top: 1.2em;
      border-top: 1px solid var(--border);
      scroll-margin-top: 70px;
    }
    /* First chapter heading has no top rule */
    .reader-body > .chapter-heading:first-child {
      margin-top: 0;
      border-top: none;
      padding-top: 0;
    }

    /* ── FONT SIZE PANEL ── */
    .font-panel {
      display: none;
      position: absolute;
      right: 0.75rem;
      top: 58px;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      box-shadow: 0 8px 24px var(--shadow);
      z-index: 200;
      min-width: 180px;
    }
    .font-panel.open { display: block; }
    .font-panel label {
      font-size: 0.8rem;
      color: var(--ink2);
      display: block;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .font-slider { width: 100%; accent-color: var(--accent); }
    .font-preview { font-size: 0.85rem; color: var(--ink2); text-align: center; margin-top: 0.3rem; }

    /* ── STATUS ── */
    .status {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--ink2);
      font-style: italic;
    }
    .status-icon { font-size: 2rem; margin-bottom: 0.5rem; }

    /* ── PROGRESS BAR ── */
    #progress-bar {
      position: fixed;
      top: 54px;
      left: 0;
      height: 2px;
      background: var(--accent);
      width: 0%;
      transition: width 0.1s;
      z-index: 99;
      display: none;
    }

    /* ── SCROLL TOP ── */
    #scroll-top {
      position: fixed;
      bottom: 1.5rem;
      right: 1.25rem;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 50%;
      width: 44px;
      height: 44px;
      font-size: 1.2rem;
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 14px var(--shadow);
      transition: transform 0.2s;
      z-index: 150;
    }
    #scroll-top:hover { transform: translateY(-2px); }

    @media (max-width: 480px) {
      #library, #reader { padding-left: 1rem; padding-right: 1rem; }
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.4s ease both; }
    .book-card:nth-child(1) { animation-delay: 0.05s; }
    .book-card:nth-child(2) { animation-delay: 0.10s; }
    .book-card:nth-child(3) { animation-delay: 0.15s; }
    .book-card:nth-child(4) { animation-delay: 0.20s; }
    .book-card:nth-child(5) { animation-delay: 0.25s; }
    .book-card:nth-child(6) { animation-delay: 0.30s; }
    .book-card:nth-child(7) { animation-delay: 0.35s; }
    .book-card:nth-child(8) { animation-delay: 0.40s; }
  </style>
</head>
<body>

<div id="progress-bar"></div>

<div id="resume-banner">
  <span id="resume-text">Continue reading?</span>
  <button onclick="resumeReading()">Resume</button>
  <button onclick="dismissResume()">✕</button>
</div>

<header>
  <div class="header-left">
    <div class="header-title" onclick="goHome()">📚 Books</div>
  </div>
  <div class="header-controls">
    <button class="icon-btn" id="toc-btn" title="Table of contents" onclick="toggleToc()" style="display:none">目次</button>
    <button class="icon-btn" id="dl-btn" title="Download file" onclick="downloadCurrent()" style="display:none">↓</button>
    <div style="position:relative">
      <button class="icon-btn" id="font-btn" title="Font size" onclick="toggleFontPanel()" style="display:none">Aa</button>
      <div class="font-panel" id="font-panel">
        <label>Reading size</label>
        <input type="range" class="font-slider" id="font-slider" min="14" max="26" value="18"
               oninput="setFontSize(this.value)">
        <div class="font-preview" id="font-preview">18px</div>
      </div>
    </div>
    <button class="icon-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
  </div>
</header>

<div id="toc-overlay" onclick="closeToc()"></div>
<div id="toc-drawer">
  <div class="toc-header">
    <span class="toc-title">目次 · Contents</span>
    <button class="toc-close" onclick="closeToc()">✕</button>
  </div>
  <div class="toc-book-title" id="toc-book-title"></div>
  <div class="toc-list" id="toc-list"></div>
</div>

<main id="library">
  <div class="status"><div class="status-icon">⏳</div>Loading your library…</div>
</main>

<div id="reader"></div>

<button id="scroll-top" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>

<script>
  const OWNER = 'onifujiba';
  const REPO  = 'books';
  const API   = `https://api.github.com/repos/${OWNER}/${REPO}/contents/`;

  let files = [];
  let dark = false;
  let currentFileKey = null;
  let chapters = [];
  let scrollSaveTimer = null;
  let resumeIndex = null;
  let resumeScroll = 0;

  // ── Theme ──────────────────────────────────────────────
  function toggleTheme() {
    dark = !dark;
    document.body.classList.toggle('dark', dark);
    document.getElementById('theme-btn').textContent = dark ? '☀️' : '🌙';
    localStorage.setItem('dark', dark);
  }
  if (localStorage.getItem('dark') === 'true') toggleTheme();

  // ── Cookie helpers ─────────────────────────────────────
  function setCookie(name, value, days = 365) {
    const expires = new Date(Date.now() + days * 864e5).toUTCString();
    document.cookie = `${name}=${encodeURIComponent(value)};expires=${expires};path=/;SameSite=Lax`;
  }
  function getCookie(name) {
    const m = document.cookie.match('(?:^|; )' + name + '=([^;]*)');
    return m ? decodeURIComponent(m[1]) : null;
  }

  // ── Font size (stored in cookie) ───────────────────────
  function setFontSize(v) {
    document.documentElement.style.setProperty('--font-size', v + 'px');
    document.getElementById('font-preview').textContent = v + 'px';
    setCookie('fontSize', v);
  }
  const savedSize = getCookie('fontSize');
  if (savedSize) {
    setFontSize(savedSize);
    document.getElementById('font-slider').value = savedSize;
  }

  // ── Download current file ──────────────────────────────
  function downloadCurrent() {
    if (!currentFileKey) return;
    const file = files.find(f => f.name === currentFileKey);
    if (!file) return;
    const a = document.createElement('a');
    a.href = file.download_url;
    a.download = file.name;
    a.target = '_blank';
    a.click();
  }

  function toggleFontPanel() {
    document.getElementById('font-panel').classList.toggle('open');
  }
  document.addEventListener('click', (e) => {
    if (!e.target.closest('#font-btn') && !e.target.closest('#font-panel'))
      document.getElementById('font-panel').classList.remove('open');
  });

  // ── TOC ────────────────────────────────────────────────
  function toggleToc() {
    document.getElementById('toc-drawer').classList.contains('open') ? closeToc() : openToc();
  }
  function openToc() {
    document.getElementById('toc-overlay').classList.add('open');
    document.getElementById('toc-drawer').classList.add('open');
    document.getElementById('toc-btn').classList.add('active');
    highlightCurrentChapter();
  }
  function closeToc() {
    document.getElementById('toc-overlay').classList.remove('open');
    document.getElementById('toc-drawer').classList.remove('open');
    document.getElementById('toc-btn').classList.remove('active');
  }

  function buildToc(chs, bookTitle) {
    document.getElementById('toc-book-title').textContent = bookTitle;
    const list = document.getElementById('toc-list');
    if (!chs.length) {
      list.innerHTML = `<div class="toc-empty">No chapters (第X章) detected in this file.</div>`;
      return;
    }
    list.innerHTML = chs.map(ch => `
      <div class="toc-item" id="toc-item-${ch.id}" onclick="jumpToChapter('${ch.id}')">
        <span class="toc-ch-label">${escHtml(ch.label)}</span>
        ${ch.title ? `<span class="toc-ch-title">${escHtml(ch.title)}</span>` : ''}
      </div>
    `).join('');
  }

  function jumpToChapter(id) {
    closeToc();
    const el = document.getElementById(id);
    if (el) {
      const y = el.getBoundingClientRect().top + window.scrollY - 70;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }
  }

  function highlightCurrentChapter() {
    if (!chapters.length) return;
    let current = chapters[0].id;
    for (const ch of chapters) {
      const el = document.getElementById(ch.id);
      if (el && el.getBoundingClientRect().top <= 90) current = ch.id;
    }
    document.querySelectorAll('.toc-item').forEach(el => el.classList.remove('current'));
    const active = document.getElementById('toc-item-' + current);
    if (active) { active.classList.add('current'); active.scrollIntoView({ block: 'nearest' }); }
  }

  // ── Scroll saving ──────────────────────────────────────
  const bar = document.getElementById('progress-bar');

  window.addEventListener('scroll', () => {
    const h = document.documentElement;
    const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
    bar.style.width = pct + '%';
    document.getElementById('scroll-top').style.display = h.scrollTop > 300 ? 'flex' : 'none';

    if (currentFileKey) {
      clearTimeout(scrollSaveTimer);
      scrollSaveTimer = setTimeout(() => {
        localStorage.setItem('scroll_' + currentFileKey, window.scrollY);
      }, 400);
    }
  });

  function saveScrollNow() {
    if (currentFileKey) localStorage.setItem('scroll_' + currentFileKey, window.scrollY);
  }
  window.addEventListener('beforeunload', saveScrollNow);

  // ── Resume banner ──────────────────────────────────────
  function checkResume(fileList) {
    const lastKey = localStorage.getItem('lastBook');
    if (!lastKey) return;
    const saved = parseInt(localStorage.getItem('scroll_' + lastKey) || '0');
    if (saved < 200) return;
    const idx = fileList.findIndex(f => f.name === lastKey);
    if (idx === -1) return;
    resumeIndex = idx;
    resumeScroll = saved;
    document.getElementById('resume-text').textContent = `Continue: ${prettify(fileList[idx].name)}`;
    document.getElementById('resume-banner').classList.add('show');
  }

  function resumeReading() {
    dismissResume();
    if (resumeIndex !== null) openBook(resumeIndex, resumeScroll);
  }
  function dismissResume() {
    document.getElementById('resume-banner').classList.remove('show');
  }

  // ── Helpers ────────────────────────────────────────────
  function prettify(name) {
    return name.replace(/\.txt$/i,'').replace(/[-_]/g,' ').replace(/\b\w/g, c => c.toUpperCase());
  }
  function escHtml(t) {
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // Chapter regex: 第1章, 第２章, 第十章, etc. — optionally followed by a title on the same line
  const CHAPTER_RE = /^(第[0-9０-９一二三四五六七八九十百千万]+章)\s*(.*)/;

  // ── Parse text → HTML + chapter list ──────────────────
  function parseText(rawText) {
    const detected = [];
    let chapCount = 0;
    let html = '';

    // Split on blank lines to get paragraphs/blocks
    const blocks = rawText.split(/\n{2,}/);

    for (const block of blocks) {
      const lines = block.split('\n').map(l => l.trim()).filter(Boolean);
      if (!lines.length) continue;

      for (const line of lines) {
        const m = line.match(CHAPTER_RE);
        if (m) {
          const id = `chapter-${++chapCount}`;
          detected.push({ id, label: m[1], title: m[2].trim() });
          html += `<div class="chapter-heading" id="${id}">${escHtml(line)}</div>`;
        } else {
          html += `<p>${escHtml(line)}</p>`;
        }
      }
    }

    return { html, chapters: detected };
  }

  // ── Library ────────────────────────────────────────────
  async function loadLibrary() {
    try {
      const res = await fetch(API);
      if (!res.ok) throw new Error('Could not reach GitHub API');
      const data = await res.json();
      files = data.filter(f => f.name.toLowerCase().endsWith('.txt'));

      const lib = document.getElementById('library');
      if (!files.length) {
        lib.innerHTML = `<div class="status"><div class="status-icon">📭</div>No .txt files found.</div>`;
        return;
      }

      lib.innerHTML = `
        <div class="library-heading fade-up">Your Library</div>
        <div class="library-sub fade-up">${files.length} stor${files.length===1?'y':'ies'} · tap to read</div>
        <div class="book-list">
          ${files.map((f,i) => {
            const scroll = parseInt(localStorage.getItem('scroll_'+f.name)||'0');
            const inProgress = scroll > 200;
            return `
              <div class="book-card fade-up" onclick="openBook(${i})">
                <div class="book-icon">${inProgress ? '🔖' : '📖'}</div>
                <div class="book-info">
                  <div class="book-name">${prettify(f.name)}</div>
                  <div class="book-meta">${f.name}</div>
                  ${inProgress ? `<div class="book-progress">Reading in progress…</div>` : ''}
                </div>
                <div class="book-arrow">›</div>
              </div>`;
          }).join('')}
        </div>`;

      checkResume(files);
    } catch(err) {
      document.getElementById('library').innerHTML =
        `<div class="status"><div class="status-icon">⚠️</div>Failed to load library.<br><small>${err.message}</small></div>`;
    }
  }

  // ── Open book ──────────────────────────────────────────
  async function openBook(index, restoreScroll = null) {
    const file = files[index];
    const readerEl = document.getElementById('reader');
    const lib = document.getElementById('library');

    currentFileKey = file.name;
    localStorage.setItem('lastBook', file.name);
    chapters = [];

    lib.style.display = 'none';
    readerEl.style.display = 'block';
    bar.style.display = 'block';
    document.getElementById('font-btn').style.display = 'flex';
    document.getElementById('toc-btn').style.display = 'flex';
    document.getElementById('dl-btn').style.display = 'flex';
    document.title = prettify(file.name) + ' · Books';

    readerEl.innerHTML = `
      <div class="reader-label">Story</div>
      <div class="reader-title">${prettify(file.name)}</div>
      <div class="status"><div class="status-icon">⏳</div>Loading…</div>`;
    window.scrollTo(0, 0);

    try {
      const res = await fetch(file.download_url);
      const text = await res.text();
      const { html, chapters: detected } = parseText(text);
      chapters = detected;

      readerEl.innerHTML = `
        <div class="reader-label fade-up">Story</div>
        <div class="reader-title fade-up">${prettify(file.name)}</div>
        <div class="reader-body fade-up">${html}</div>`;

      buildToc(chapters, prettify(file.name));

      // Restore scroll
      const target = restoreScroll !== null
        ? restoreScroll
        : parseInt(localStorage.getItem('scroll_' + file.name) || '0');

      if (target > 0) {
        requestAnimationFrame(() => requestAnimationFrame(() => window.scrollTo(0, target)));
      }

    } catch(err) {
      readerEl.innerHTML += `<div class="status">⚠️ Could not load file.<br><small>${err.message}</small></div>`;
    }
  }

  // ── Go home ────────────────────────────────────────────
  function goHome() {
    saveScrollNow();
    currentFileKey = null;
    chapters = [];
    closeToc();
    document.getElementById('reader').style.display = 'none';
    document.getElementById('library').style.display = 'block';
    bar.style.display = 'none';
    bar.style.width = '0%';
    document.getElementById('font-btn').style.display = 'none';
    document.getElementById('toc-btn').style.display = 'none';
    document.getElementById('dl-btn').style.display = 'none';
    document.title = 'Books';
    window.scrollTo(0, 0);
    loadLibrary(); // refresh progress badges
  }

  window.addEventListener('popstate', goHome);
  loadLibrary();
</script>
</body>
</html>
